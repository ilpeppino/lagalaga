# Server
NODE_ENV=development
PORT=3001
HOST=0.0.0.0

# Logging (Epic 8)
LOG_LEVEL=debug  # Options: trace, debug, info, warn, error, fatal

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key  # NEVER expose to client - bypasses RLS
SUPABASE_ANON_KEY=your-anon-key  # Optional - for user-scoped operations (enforces RLS)

# Roblox OAuth
ROBLOX_CLIENT_ID=your-client-id
ROBLOX_CLIENT_SECRET=your-client-secret
ROBLOX_REDIRECT_URI=lagalaga://auth/roblox

# Google OAuth / OIDC
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/google/callback
GOOGLE_ISSUER=https://accounts.google.com
# Optional override. Leave empty to use OIDC discovery/defaults.
GOOGLE_JWKS_URI=

# Apple Sign-In / OIDC
APPLE_BUNDLE_ID=com.ilpeppino.lagalaga
# Optional comma-separated list. If set, overrides APPLE_BUNDLE_ID as accepted audience(s).
APPLE_AUDIENCE=
APPLE_ISSUER=https://appleid.apple.com
# Optional override. Leave empty to use Apple default.
APPLE_JWKS_URI=

# JWT
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_EXPIRY=15m
REFRESH_TOKEN_SECRET=different-secret-for-refresh
REFRESH_TOKEN_EXPIRY=7d

# CORS
# Comma-separated origins. Use explicit origins in production; never "*".
CORS_ORIGIN=http://localhost:19006

# Quick Play
DEFAULT_PLACE_ID=1818  # Example: Roblox Classic Crossroads (fallback for quick play)

# Sprint 3: Competitive Depth & Retention Layer
ENABLE_COMPETITIVE_DEPTH=false

# Session lifecycle maintenance job
SESSION_LIFECYCLE_ENABLED=true
SESSION_LIFECYCLE_INTERVAL_MINUTES=15
SESSION_AUTO_COMPLETE_AFTER_HOURS=2
SESSION_COMPLETED_RETENTION_HOURS=2
SESSION_LIFECYCLE_BATCH_SIZE=200

# Cache cleanup maintenance job
CACHE_CLEANUP_ENABLED=true
CACHE_CLEANUP_INTERVAL_HOURS=6

# Metrics endpoint protection
# In production, set this to require Authorization: Bearer <token> for /metrics and /metrics/json.
METRICS_BEARER_TOKEN=90b5b7a29fa3e8ea706146216a0b9eaaabfde15f97cd1a4f7940571b9fc0a38d0ca2873cc61fbd300abc920a3f1b4c457504b8a08b8653d3508ef316c0e02b4d

# Safety escalation alerts
# Webhook endpoint that receives CSAM (and optional grooming) escalation events.
SAFETY_ALERT_WEBHOOK_URL=
# Shared secret used by webhook sender and receiver.
SAFETY_WEBHOOK_TOKEN=
# Resend API key for delivering safety escalation emails.
RESEND_API_KEY=
# Real safety inbox destination.
SAFETY_MAIL_TO=
# Verified sender/domain in Resend.
SAFETY_MAIL_FROM=
# Optional app environment label for email subject prefix (e.g. production, staging).
APP_ENV=
# Set true to escalate GROOMING_OR_SEXUAL_EXPLOITATION using the same webhook path.
SAFETY_ESCALATE_GROOMING=false
